      $('trainerSearch').addEventListener('input', e=> renderResults(e.target.value));
      $('trainerSearch').addEventListener('focus', e=> { if(e.target.value) renderResults(e.target.value); });
      $('trainerClearBtn').addEventListener('click', ()=>{
        state.trainerId = null;
        state.traineeRecordId = null;
        $('trainerSelectedWrap').style.display = 'none';
        $('trainerSearch').style.display = 'block';
        $('trainerSearch').value = '';
        $('traineeFieldWrap').style.display = 'none';
      });

      function renderTraineeResults(query){
        const box = $('traineeResults');
        const list = state.traineesForCoach || [];
        const q = query.trim().toLowerCase();
        const matches = (q ? list.filter(tr => (tr.firstName+' '+tr.lastName).toLowerCase().includes(q)) : list).slice(0,10);
        if(matches.length===0){
          box.innerHTML = '<div class="opt" style="color:var(--muted);">לא נמצאו מתאמנים תואמים</div>';
          box.classList.add('show');
          return;
        }
        box.innerHTML = matches.map(tr => `<div class="opt" data-id="${tr.id}">${tr.firstName} ${tr.lastName}<div class="sub">${tr.email||''}</div></div>`).join('');
        box.classList.add('show');
        box.querySelectorAll('.opt[data-id]').forEach(el=>{
          el.addEventListener('click', ()=> selectTrainee(el.dataset.id));
        });
      }
      function selectTrainee(id){
        const tr = (state.traineesForCoach||[]).find(x=>x.id===id);
        if(!tr) return;
        state.traineeRecordId = tr.id;
        state.trainee_name = `${tr.firstName} ${tr.lastName}`.trim();
        state.trainee_email = tr.email || '';
        state.trainee_phone = tr.phone || '';
        $('traineeSearch').value = '';
        $('traineeResults').classList.remove('show');
        $('traineeSelectedLabel').textContent = state.trainee_name;
        $('traineeSelectedWrap').style.display = 'block';
        $('traineeSearch').style.display = 'none';
        setErr('err0b', false);
      }
      $('traineeClearBtn') && $('traineeClearBtn').addEventListener('click', ()=>{
        state.traineeRecordId = null;
        $('traineeSelectedWrap').style.display = 'none';
        $('traineeSearch').style.display = 'block';
        $('traineeSearch').value = '';
      });
      $('traineeSearch') && $('traineeSearch').addEventListener('input', e=> renderTraineeResults(e.target.value));
      $('traineeSearch') && $('traineeSearch').addEventListener('focus', e=> renderTraineeResults(e.target.value));

      // Restore selection if the trainee navigated back to this step
      if(state.trainerId){
        $('trainerSelectedLabel').textContent = state.trainerName;
        $('trainerSelectedWrap').style.display = 'block';
        $('trainerSearch').style.display = 'none';
        $('traineeFieldWrap').style.display = 'block';
        if(state.traineeRecordId){
          $('traineeSelectedLabel').textContent = state.trainee_name;
          $('traineeSelectedWrap').style.display = 'block';
          $('traineeSearch').style.display = 'none';
        }
      }
    }

    function step1(){
      return `
        <div class="card">
          <h2>פרטי המתאמן/ת</h2>
          <p class="hint">הפרטים הבאים מולאו מהמערכת — נא לעדכן אם משהו השתנה</p>
          <div class="field"><label>שם פרטי ומשפחה</label><input type="text" id="f_name" placeholder="לדוגמה: ישראל ישראלי"></div>
          <div class="field"><label>דוא"ל</label><input type="email" id="f_email" placeholder="name@example.com"></div>
          <div class="field"><label>נייד</label><input type="tel" id="f_phone" placeholder="050-0000000"></div>
          <div class="field"><label>כתובת</label><input type="text" id="f_address" placeholder="עיר, רחוב ומספר"></div>
          <div class="row2">
            <div class="field"><label>תאריך לידה</label><input type="date" id="f_dob"></div>
            <div class="field"><label>מצב משפחתי</label>
              <select id="f_marital">
                <option value="">בחר/י</option>
                <option>רווק/ה</option><option>נשוי/אה</option><option>גרוש/ה</option><option>אלמן/ה</option><option>אחר</option>
              </select>
            </div>
          </div>
          <div class="field"><label>פרטי עיסוק</label><input type="text" id="f_occupation" placeholder="תחום עיסוק / תפקיד"></div>
          <div class="error-text" id="err1">נא למלא שם, דוא"ל ונייד לפני המשך.</div>
        </div>
      `;
    }

    function step2(){
      return `
        <div class="card">
          <h2>מצב בריאותי</h2>
          <p class="hint">המידע נשמר בסודיות מוחלטת ומשמש את המאמן/ת בלבד</p>
          <div class="yn-block" data-q="q1">
            <div class="yn-q">האם היית בעבר בטיפול פסיכולוגי, פסיכיאטרי, או אימוני כלשהו?</div>
            <div class="yn-options"><label><input type="radio" name="q1" value="כן"> כן</label><label><input type="radio" name="q1" value="לא"> לא</label></div>
            <div class="yn-detail"><input type="text" id="q1_detail" placeholder="ציין/י איזה"></div>
          </div>
          <div class="yn-block" data-q="q2">
            <div class="yn-q">האם אובחנת או הינך סובל/ת ממחלה נפשית כלשהי?</div>
            <div class="yn-options"><label><input type="radio" name="q2" value="כן"> כן</label><label><input type="radio" name="q2" value="לא"> לא</label></div>
            <div class="yn-detail"><input type="text" id="q2_detail" placeholder="ציין/י איזו"></div>
          </div>
          <div class="yn-block" data-q="q3">
            <div class="yn-q">האם את/ה נוטל/ת תרופות באופן קבוע?</div>
            <div class="yn-options"><label><input type="radio" name="q3" value="כן"> כן</label><label><input type="radio" name="q3" value="לא"> לא</label></div>
            <div class="yn-detail"><input type="text" id="q3_detail" placeholder="ציין/י איזה"></div>
          </div>
          <div class="error-text" id="err2">נא לענות על כל השאלות.</div>
        </div>
      `;
    }

    function step3(){
      return `<div class="card">${TERMS_HTML}
        <div class="confirm-row"><input type="checkbox" id="agree1"><span>קראתי ואני מאשר/ת את תהליך האימון, ההתחייבויות, הסודיות וגילוי הנאות כמפורט לעיל.</span></div>
        <div class="error-text" id="err3">יש לאשר את התנאים לפני המשך.</div>
      </div>`;
    }

    function step4(){
      return `
        <div class="card">
          <h2>חתימת המתאמן/ת</h2>
          <p class="hint">חתום/חתמי באמצעות האצבע או העכבר בתיבה שלהלן</p>
          <div class="sig-pad-wrap"><canvas class="sigpad" id="sigTrainee"></canvas><div class="sig-line-label">חתימת המתאמן/ת</div></div>
          <button class="sig-clear" id="clearSig">נקה חתימה</button>
          <div class="error-text" id="err4">נא לחתום לפני שליחה.</div>
        </div>
      `;
    }

    function step5(){
      return `
        <div class="card">
          <span class="badge wait" id="statusBadge">ממתין להפקת קישור ושליחה למאמן/ת</span>
          <h2>סיכום ואישור</h2>
          <p class="hint">בדוק/י את הפרטים ואז שלח/י את הטופס</p>
          <div id="summaryBox"></div>
        </div>
      `;
    }

    function renderStep(){
      const renderers = [step0, step1, step2, step3, step4, step5];
      $('content').innerHTML = renderers[current]();
      updateDots();
      if(current===0) wireStep0();
      if(current===1) prefillTraineeFields();
      if(current===2) wireStep2();
      if(current===4) setupPad($('sigTrainee')) , $('clearSig').onclick = ()=> $('sigTrainee')._clear();
      if(current===5) renderSummary();
      renderNav();
      window.scrollTo({top:0, behavior:'smooth'});
    }

    function prefillTraineeFields(){
      if(state.trainee_name) $('f_name').value = state.trainee_name;
      if(state.trainee_email) $('f_email').value = state.trainee_email;
      if(state.trainee_phone) $('f_phone').value = state.trainee_phone;
      if(state.trainee_address) $('f_address').value = state.trainee_address;
      if(state.trainee_dob) $('f_dob').value = state.trainee_dob;
      if(state.trainee_marital) $('f_marital').value = state.trainee_marital;
      if(state.trainee_occupation) $('f_occupation').value = state.trainee_occupation;
    }

    function wireStep2(){
      qAll('.yn-block').forEach(block=>{
        const detail = block.querySelector('.yn-detail');
        block.querySelectorAll('input[type=radio]').forEach(radio=>{
          if(state.health[radio.name] === radio.value){
            radio.checked = true;
            radio.closest('label').classList.add('checked');
            if(radio.value==='כן') detail.classList.add('show');
          }
          radio.addEventListener('change', ()=>{
            block.querySelectorAll('.yn-options label').forEach(l=>l.classList.remove('checked'));
            radio.closest('label').classList.add('checked');
            detail.classList.toggle('show', radio.value === 'כן');
          });
        });
      });
    }

    function renderNav(){
      const box = $('navButtons');
      box.innerHTML = '';
      if(current > 0 && current < 6){
        const back = document.createElement('button');
        back.className = 'btn btn-secondary';
        back.textContent = 'חזרה';
        back.onclick = ()=>{ current--; renderStep(); };
        box.appendChild(back);
      }
      if(current < 5){
        const next = document.createElement('button');
        next.className = 'btn btn-primary';
        next.textContent = 'הבא';
        next.onclick = handleNext;
        box.appendChild(next);
      } else {
        const send = document.createElement('button');
        send.className = 'btn btn-primary';
        send.textContent = 'שלח טופס וצור קישור למאמן/ת';
        send.onclick = finalizeSubmission;
        box.appendChild(send);
      }
    }

    function handleNext(){
      if(current===0){
        if(!state.trainerId){ setErr('err0', true); return; }
        setErr('err0', false);
        if(!state.traineeRecordId){ setErr('err0b', true); return; }
        setErr('err0b', false);
      }
      if(current===1){
        const name = $('f_name').value.trim();
        const email = $('f_email').value.trim();
        const phone = $('f_phone').value.trim();
        if(!name || !email || !phone){ setErr('err1', true); return; }
        setErr('err1', false);
        state.trainee_name = name; state.trainee_email = email; state.trainee_phone = phone;
        state.trainee_address = $('f_address').value.trim();
        state.trainee_dob = $('f_dob').value;
        state.trainee_marital = $('f_marital').value;
        state.trainee_occupation = $('f_occupation').value.trim();
      }
      if(current===2){
        const q1 = document.querySelector('input[name=q1]:checked');
        const q2 = document.querySelector('input[name=q2]:checked');
        const q3 = document.querySelector('input[name=q3]:checked');
        if(!q1||!q2||!q3){ setErr('err2', true); return; }
        setErr('err2', false);
        state.health = {
          q1: q1.value, q1_detail: $('q1_detail').value.trim(),
          q2: q2.value, q2_detail: $('q2_detail').value.trim(),
          q3: q3.value, q3_detail: $('q3_detail').value.trim(),
        };
      }
      if(current===3){
        if(!$('agree1').checked){ setErr('err3', true); return; }
        setErr('err3', false);
      }
      if(current===4){
        const pad = $('sigTrainee');
        if(!pad._hasInk()){ setErr('err4', true); return; }
        setErr('err4', false);
        state.traineeSignature = pad._dataUrl();
        state.traineeSignedAt = new Date().toISOString();
      }
      current++; renderStep();
    }

    function renderSummary(){
      const rows = [
        ['מאמן/ת', state.trainerName],
        ['מתאמן/ת', state.trainee_name],
        ['דוא"ל', state.trainee_email],
        ['נייד', state.trainee_phone],
        ['כתובת', state.trainee_address || '—'],
        ['תאריך לידה', state.trainee_dob || '—'],
        ['מצב משפחתי', state.trainee_marital || '—'],
        ['עיסוק', state.trainee_occupation || '—'],
      ];
      $('summaryBox').innerHTML = rows.map(r=>`<div class="summary-row"><span class="k">${r[0]}</span><span class="v">${r[1]}</span></div>`).join('');
    }

    async function finalizeSubmission(){
      $('loadingOverlay').classList.add('show');
      $('loadingText').textContent = 'שומר ויוצר קישור...';
      try{
        const record = {
          trainerId: state.trainerId, trainerName: state.trainerName, trainerEmail: state.trainerEmail,
          trainee: {
            name: state.trainee_name, email: state.trainee_email, phone: state.trainee_phone,
            address: state.trainee_address, dob: state.trainee_dob, marital: state.trainee_marital, occupation: state.trainee_occupation
          },
          health: state.health,
          traineeSignature: state.traineeSignature,
          traineeSignedAt: state.traineeSignedAt,
          coachSignature: null,
          coachSignedAt: null,
        };

        const token = await submitAgreement(state.traineeRecordId, record);
        const link = buildLink(token);

        const subject = encodeURIComponent('השלמת חתימה - טופס תהליך אימון: ' + record.trainee.name);
        const body = encodeURIComponent(
          `שלום ${record.trainerName},\n\n` +
          `${record.trainee.name} מילא/ה וחתם/ה על טופס פרטי מתאמן ותהליך אימון.\n` +
          `להשלמת התהליך, נא לפתוח את הקישור ולהוסיף את חתימתך:\n\n${link}\n\n` +
          `בית הספר למנהיגות תודעתית`
        );
        const mailtoHref = `mailto:${encodeURIComponent(record.trainerEmail||'')}?subject=${subject}&body=${body}`;

        $('statusBadge').textContent = 'הטופס נשמר! כעת יש לשתף את הקישור עם המאמן/ת';
        $('statusBadge').className = 'badge done';

        $('content').innerHTML = `
          <div class="card">
            <span class="badge done">נשלח בהצלחה</span>
            <h2>תודה, ${record.trainee.name}!</h2>
            <p class="hint">החתימה שלך נשמרה. כדי לסיים את התהליך, יש להעביר את הקישור הבא ל${record.trainerName} כדי שיחתום/תחתום גם הוא/היא.</p>
            <input class="link-box" id="linkBox" readonly value="${link.replace(/"/g,'&quot;')}">
            <p class="hint" style="margin:4px 0 10px;font-size:12px;">אם ההעתקה האוטומטית לא עובדת, אפשר ללחוץ על השדה ולהעתיק ידנית (החזק/י והעתק/י).</p>
            <button class="copy-btn" id="copyLinkBtn">העתק קישור</button>
            <a class="btn btn-primary btn-full" style="margin-top:10px;" href="${mailtoHref}">פתח טיוטת מייל למאמן/ת</a>
            <button class="btn btn-secondary btn-full" style="margin-top:10px;" id="downloadPdfBtn">הורד PDF (חתימת מתאמן בלבד)</button>
          </div>
        `;
        $('navButtons').innerHTML = '';
        $('linkBox').addEventListener('click', ()=> $('linkBox').select());
        $('copyLinkBtn').addEventListener('click', ()=> copyLinkToClipboard(link));
        $('downloadPdfBtn').addEventListener('click', ()=> downloadPdfWithFeedback(record));
      } catch(e){
        console.error(e);
        $('content').innerHTML = `
          <div class="card">
            <span class="badge wait" style="background:#FBEFE9;color:var(--accent);">שגיאה</span>
            <h2>קרתה תקלה לא צפויה</h2>
            <p class="hint">החתימה שלך נקלטה, אך נכשלנו בשמירה (${(e&&e.message)||'שגיאה לא ידועה'}). אפשר לנסות שוב, או להוריד PDF עם הפרטים והחתימה ולשלוח אותו ישירות.</p>
          </div>
        `;
        $('navButtons').innerHTML = '';
        const retryBtn = document.createElement('button');
        retryBtn.className = 'btn btn-primary btn-full';
        retryBtn.textContent = 'נסה לשמור שוב';
        retryBtn.onclick = finalizeSubmission;
        $('navButtons').appendChild(retryBtn);
        const pdfFallbackBtn = document.createElement('button');
        pdfFallbackBtn.className = 'btn btn-secondary btn-full';
        pdfFallbackBtn.style.marginTop = '10px';
        pdfFallbackBtn.textContent = 'הורד PDF עם הפרטים שלי';
        pdfFallbackBtn.onclick = ()=> downloadPdfWithFeedback({
          trainerName: state.trainerName, trainerEmail: state.trainerEmail,
          trainee: {
            name: state.trainee_name, email: state.trainee_email, phone: state.trainee_phone,
            address: state.trainee_address, dob: state.trainee_dob, marital: state.trainee_marital, occupation: state.trainee_occupation
          },
          health: state.health,
          traineeSignature: state.traineeSignature, traineeSignedAt: state.traineeSignedAt,
          coachSignature: null, coachSignedAt: null
        });
        $('navButtons').appendChild(pdfFallbackBtn);
      } finally {
        $('loadingOverlay').classList.remove('show');
      }
    }

    // Single delegated listener for the whole trainee flow, registered once, always null-safe.
    document.addEventListener('click', (e)=>{
      const results = $('trainerResults');
      if(results && !e.target.closest('#trainerResults') && e.target.id !== 'trainerSearch'){
        results.classList.remove('show');
      }
    });

    return { start: ()=>{ renderProgress(); renderStep(); } };
  })();

  // ================= COACH FLOW =================
  const CoachFlow = (function(){
    let record = null;

    function renderLoading(){
      $('progressBar').innerHTML = '';
      $('content').innerHTML = `<div class="card"><p class="hint">טוען את הטופס...</p></div>`;
      $('navButtons').innerHTML = '';
    }

    function renderNotFound(){
      $('content').innerHTML = `
        <div class="card success-screen">
          <div class="check" style="background:#FBEFE9;color:var(--accent);">!</div>
          <h2>הטופס לא נמצא</h2>
          <p>הקישור שגוי או שהטופס נמחק. נא לבדוק את הקישור עם המתאמן/ת ששלח/ה אותו.</p>
        </div>
      `;
      $('navButtons').innerHTML = '';
    }

    function renderSummaryReadonly(r){
      const rows = [
        ['מתאמן/ת', r.trainee.name],
        ['דוא"ל', r.trainee.email],
        ['נייד', r.trainee.phone],
        ['כתובת', r.trainee.address || '—'],
        ['תאריך לידה', r.trainee.dob || '—'],
        ['מצב משפחתי', r.trainee.marital || '—'],
        ['עיסוק', r.trainee.occupation || '—'],
        ['טיפול קודם', r.health.q1 + (r.health.q1_detail ? ' · '+r.health.q1_detail : '')],
        ['מחלה נפשית', r.health.q2 + (r.health.q2_detail ? ' · '+r.health.q2_detail : '')],
        ['תרופות קבועות', r.health.q3 + (r.health.q3_detail ? ' · '+r.health.q3_detail : '')],
