      ];
      return `<div class="readonly-card">${rows.map(x=>`<div class="summary-row"><span class="k">${x[0]}</span><span class="v">${x[1]}</span></div>`).join('')}</div>`;
    }

    function renderPendingView(r){
      $('progressBar').innerHTML = '';
      $('content').innerHTML = `
        <div class="card">
          <span class="badge wait">ממתין לחתימתך</span>
          <h2>שלום ${r.trainerName}</h2>
          <p class="hint">${r.trainee.name} מילא/ה וחתם/ה על הטופס. נא לעיין בפרטים ולהוסיף את חתימתך להשלמת התהליך.</p>
          ${renderSummaryReadonly(r)}
          <div style="margin-bottom:14px;">
            <button type="button" id="toggleTerms" class="btn btn-secondary btn-full" style="margin-bottom:10px;">הצג/הסתר את תנאי התהליך המלאים</button>
            <div id="termsBlock" style="display:none;">${TERMS_HTML}</div>
          </div>
          <h2>חתימת המאמן/ת</h2>
          <div class="sig-pad-wrap"><canvas class="sigpad" id="sigCoach"></canvas><div class="sig-line-label">חתימת המאמן/ת</div></div>
          <button class="sig-clear" id="clearCoachSig">נקה חתימה</button>
          <div class="error-text" id="errCoach">נא לחתום לפני אישור.</div>
        </div>
      `;
      setupPad($('sigCoach'));
      $('clearCoachSig').onclick = ()=> $('sigCoach')._clear();
      $('toggleTerms').onclick = ()=>{
        const b = $('termsBlock');
        b.style.display = b.style.display === 'none' ? 'block' : 'none';
      };

      $('navButtons').innerHTML = '';
      const confirmBtn = document.createElement('button');
      confirmBtn.className = 'btn btn-primary btn-full';
      confirmBtn.textContent = 'אשר וחתום';
      confirmBtn.onclick = async ()=>{
        const pad = $('sigCoach');
        if(!pad._hasInk()){ $('errCoach').classList.add('show'); return; }
        $('errCoach').classList.remove('show');
        $('loadingOverlay').classList.add('show');
        $('loadingText').textContent = 'שומר חתימה...';
        try{
          const coachSignature = pad._dataUrl();
          const coachSignedAt = new Date().toISOString();
          const updated = await completeAgreement(r.token, coachSignature, coachSignedAt);
          renderCompletedView(updated);
        } catch(e){
          console.error(e);
          $('content').innerHTML = `
            <div class="card">
              <span class="badge wait" style="background:#FBEFE9;color:var(--accent);">שגיאה</span>
              <h2>קרתה תקלה לא צפויה</h2>
              <p class="hint">${(e&&e.message)||'שגיאה לא ידועה'}. אפשר לנסות שוב, או להוריד PDF עם הפרטים הקיימים.</p>
            </div>
          `;
          $('navButtons').innerHTML = '';
          const retryBtn = document.createElement('button');
          retryBtn.className = 'btn btn-primary btn-full';
          retryBtn.textContent = 'נסה לשמור שוב';
          retryBtn.onclick = ()=> renderPendingView(r);
          $('navButtons').appendChild(retryBtn);
          const pdfBtn = document.createElement('button');
          pdfBtn.className = 'btn btn-secondary btn-full';
          pdfBtn.style.marginTop = '10px';
          pdfBtn.textContent = 'הורד PDF עם המצב הנוכחי';
          pdfBtn.onclick = ()=> downloadPdfWithFeedback(r);
          $('navButtons').appendChild(pdfBtn);
        } finally {
          $('loadingOverlay').classList.remove('show');
        }
      };
      $('navButtons').appendChild(confirmBtn);
    }

    function renderCompletedView(r){
      $('progressBar').innerHTML = '';
      $('content').innerHTML = `
        <div class="card success-screen">
          <div class="check">✓</div>
          <h2>התהליך הושלם!</h2>
          <p>שני הצדדים חתמו על הטופס. ניתן להוריד כעת את ה-PDF הסופי הכולל את שתי החתימות.</p>
          <button class="btn btn-primary btn-full" id="downloadFinalPdf">הורד PDF סופי</button>
        </div>
      `;
      $('navButtons').innerHTML = '';
      $('downloadFinalPdf').addEventListener('click', ()=> downloadPdfWithFeedback(r));
    }

    async function start(token){
      renderLoading();
      record = await loadAgreementByToken(token);
      if(!record){ renderNotFound(); return; }
      record.token = token;
      if(record.status === 'completed'){ renderCompletedView(record); }
      else { renderPendingView(record); }
    }

    return { start };
  })();

  // ================= ROUTER =================
  const params = new URLSearchParams(window.location.search);
  const tokenParam = params.get('token');
  if(tokenParam){
    CoachFlow.start(tokenParam);
  } else {
    TraineeFlow.start();
  }
})();
</script>
</body>
</html>
