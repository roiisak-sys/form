  // Copies text using whichever mechanism actually works in the current context.
  // The async Clipboard API is frequently blocked by permissions policy inside
  // sandboxed iframes (e.g. artifact previews) and fails *silently* if nothing
  // catches the rejection — that silent failure is what made the link look
  // "invalid" (nothing was ever actually on the clipboard). This always reports
  // honestly whether the copy worked, and falls back to manual selection.
  async function copyLinkToClipboard(text){
    const btn = $('copyLinkBtn');
    const input = $('linkBox');
    let copied = false;

    if(navigator.clipboard && navigator.clipboard.writeText){
      try{
        await navigator.clipboard.writeText(text);
        copied = true;
      } catch(e){
        copied = false;
      }
    }

    if(!copied && input){
      try{
        input.removeAttribute('disabled');
        input.focus();
        input.select();
        input.setSelectionRange(0, text.length);
        copied = document.execCommand && document.execCommand('copy');
      } catch(e){
        copied = false;
      }
    }

    if(btn){
      if(copied){
        btn.textContent = '✓ הועתק!';
        btn.classList.add('copied');
        setTimeout(()=>{ btn.textContent = 'העתק קישור'; btn.classList.remove('copied'); }, 2500);
      } else {
        btn.textContent = 'ההעתקה לא הצליחה — סמן/י ידנית למעלה';
        if(input){ input.focus(); input.select(); }
        setTimeout(()=>{ btn.textContent = 'העתק קישור'; }, 3500);
      }
    }
    return copied;
  }

  // ---------------- signature pad ----------------
  function setupPad(canvas){
    const ctx = canvas.getContext('2d');
    function resize(){
      const ratio = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * ratio;
      canvas.height = rect.height * ratio;
      ctx.scale(ratio, ratio);
      ctx.lineWidth = 2.2;
      ctx.lineCap = 'round';
      ctx.strokeStyle = '#1A2B4C';
    }
    resize();
    let drawing = false, hasInk = false, lastX=0, lastY=0;
    function pos(e){
      const rect = canvas.getBoundingClientRect();
      const cx = e.touches ? e.touches[0].clientX : e.clientX;
      const cy = e.touches ? e.touches[0].clientY : e.clientY;
      return {x: cx-rect.left, y: cy-rect.top};
    }
    function start(e){ e.preventDefault(); drawing=true; hasInk=true; const p=pos(e); lastX=p.x; lastY=p.y; }
    function move(e){
      if(!drawing) return;
      e.preventDefault();
      const p = pos(e);
      ctx.beginPath(); ctx.moveTo(lastX,lastY); ctx.lineTo(p.x,p.y); ctx.stroke();
      lastX=p.x; lastY=p.y;
    }
    function end(){ drawing=false; }
    canvas.addEventListener('mousedown', start);
    canvas.addEventListener('mousemove', move);
    window.addEventListener('mouseup', end);
    canvas.addEventListener('touchstart', start, {passive:false});
    canvas.addEventListener('touchmove', move, {passive:false});
    canvas.addEventListener('touchend', end);
    canvas._hasInk = ()=>hasInk;
    canvas._clear = ()=>{ ctx.clearRect(0,0,canvas.width,canvas.height); hasInk=false; };
    canvas._dataUrl = ()=> canvas.toDataURL('image/png');
  }

  // ---------------- Hebrew RTL text helpers ----------------
  // jsPDF always draws characters left-to-right regardless of Unicode
  // direction, so Hebrew needs the run order and Hebrew-run character order
  // manually reversed before rendering. Latin/numeric runs (emails, phone
  // numbers, dates) are left untouched internally so they don't render
  // backwards — only their position within the line shifts.
  function isHebrewChar(ch){
    const code = ch.codePointAt(0);
    return code >= 0x0590 && code <= 0x05FF;
  }
  function isLatinOrDigit(ch){
    const code = ch.codePointAt(0);
    return (code >= 0x0041 && code <= 0x005A) || (code >= 0x0061 && code <= 0x007A) || (code >= 0x0030 && code <= 0x0039);
  }
  function classifyChar(ch){
    if(isHebrewChar(ch)) return 'rtl';
    if(isLatinOrDigit(ch)) return 'ltr';
    return 'neutral';
  }
  function reorderBidiLine(text){
    if(!text) return text;
    const chars = Array.from(String(text));
    const types = chars.map(classifyChar);
    for(let i=0; i<types.length; i++){
      if(types[i] !== 'neutral') continue;
      let next = null;
      for(let j=i+1; j<types.length; j++){ if(types[j] !== 'neutral'){ next = types[j]; break; } }
      let prev = null;
      for(let j=i-1; j>=0; j--){ if(types[j] !== 'neutral'){ prev = types[j]; break; } }
      types[i] = next || prev || 'rtl';
    }
    const runs = [];
    let curType = types[0];
    let curChars = [chars[0]];
    for(let i=1; i<chars.length; i++){
      if(types[i] === curType){ curChars.push(chars[i]); }
      else { runs.push({ rtl: curType==='rtl', text: curChars.join('') }); curType = types[i]; curChars = [chars[i]]; }
    }
    runs.push({ rtl: curType==='rtl', text: curChars.join('') });
    return runs.reverse().map(r => r.rtl ? Array.from(r.text).reverse().join('') : r.text).join('');
  }

  // ---------------- PDF generation ----------------
  // Renders entirely with jsPDF's own text/font/image APIs (no html2canvas, no
  // off-screen iframe rendering) — that approach is unreliable inside an
  // already-sandboxed artifact iframe. A real Hebrew font (Noto Sans Hebrew,
  // subsetted) is embedded directly into the PDF, and Hebrew lines are
  // reordered with reorderBidiLine() before drawing, right-aligned to the
  // page's right margin to match natural Hebrew reading direction.
  const PDF_PAGE_W_MM = 210;
  const PDF_PAGE_H_MM = 297;
  const PDF_MARGIN_MM = 16;
  const PDF_CONTENT_W_MM = PDF_PAGE_W_MM - 2*PDF_MARGIN_MM;

  function registerHebrewFonts(doc){
    doc.addFileToVFS('NotoSansHebrew-Regular.ttf', HEBREW_FONT_REGULAR_BASE64);
    doc.addFont('NotoSansHebrew-Regular.ttf', 'NotoHebrew', 'normal');
    doc.addFileToVFS('NotoSansHebrew-Bold.ttf', HEBREW_FONT_BOLD_BASE64);
    doc.addFont('NotoSansHebrew-Bold.ttf', 'NotoHebrew', 'bold');
  }

  function hebrewText(doc, text, xRight, y, opts){
    opts = opts || {};
    doc.text(reorderBidiLine(text), xRight, y, Object.assign({ align: 'right' }, opts));
  }

  // Wraps a Hebrew paragraph at word boundaries (measured in logical/original
  // order, which is safe since wrapping only needs substring pixel widths),
  // then reverses each resulting line for correct visual rendering.
  function hebrewParagraph(doc, text, xRight, y, maxWidthMm, lineHeightMm){
    const logicalLines = doc.splitTextToSize(text, maxWidthMm);
    logicalLines.forEach(line=>{
      hebrewText(doc, line, xRight, y);
      y += lineHeightMm;
    });
    return y;
  }

  async function generatePdf(data){
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit: 'mm', format: 'a4' });
    registerHebrewFonts(doc);
    doc.setFont('NotoHebrew', 'normal');

    const xRight = PDF_PAGE_W_MM - PDF_MARGIN_MM;
    const xLeft = PDF_MARGIN_MM;
    let y = 0;

    function drawBanner(){
      doc.setFillColor(26,43,76);
      doc.rect(0, 0, PDF_PAGE_W_MM, 24, 'F');
      doc.setTextColor(255,255,255);
      doc.setFont('NotoHebrew','bold'); doc.setFontSize(13);
      hebrewText(doc, 'בית הספר למנהיגות תודעתית', xRight, 11);
      doc.setFont('NotoHebrew','normal'); doc.setFontSize(8.5);
      hebrewText(doc, 'טופס פרטי מתאמן ותהליך אימון', xRight, 18);
      y = 32;
    }
    function drawFooter(pageNum, pageTotal){
      doc.setDrawColor(26,43,76); doc.setLineWidth(0.3);
      doc.line(PDF_MARGIN_MM, PDF_PAGE_H_MM-14, xRight, PDF_PAGE_H_MM-14);
      doc.setFont('NotoHebrew','normal'); doc.setFontSize(7.5); doc.setTextColor(120,120,120);
      hebrewText(doc, 'בית הספר למנהיגות תודעתית · talbashan.co.il', xRight, PDF_PAGE_H_MM-9);
      doc.text(String(pageNum) + ' / ' + String(pageTotal), PDF_PAGE_W_MM/2, PDF_PAGE_H_MM-9, {align:'center'});
    }
    function ensureSpace(neededMm){
      if(y + neededMm > PDF_PAGE_H_MM - 18){
        doc.addPage();
        drawBanner();
      }
    }
    function sectionTitle(t){
      ensureSpace(12);
      doc.setFont('NotoHebrew','bold'); doc.setFontSize(12); doc.setTextColor(26,43,76);
      hebrewText(doc, t, xRight, y);
      y += 6;
    }
    function row(label, value){
      doc.setFont('NotoHebrew','bold'); doc.setFontSize(9.5);
      const labelLines = doc.splitTextToSize(label, PDF_CONTENT_W_MM);
      doc.setFont('NotoHebrew','normal'); doc.setFontSize(9.5);
      const valueLines = doc.splitTextToSize(String(value||'—'), PDF_CONTENT_W_MM);
      ensureSpace((labelLines.length + valueLines.length) * 4.6 + 2);

      doc.setFont('NotoHebrew','bold'); doc.setTextColor(26,43,76);
      labelLines.forEach(line=>{ hebrewText(doc, line, xRight, y); y += 4.6; });
      doc.setFont('NotoHebrew','normal'); doc.setTextColor(26,26,26);
      valueLines.forEach(line=>{ hebrewText(doc, line, xRight, y); y += 4.6; });
      y += 1.5;
    }
    function paragraph(text){
      doc.setFont('NotoHebrew','normal'); doc.setFontSize(9.3); doc.setTextColor(26,26,26);
      const lines = doc.splitTextToSize(text, PDF_CONTENT_W_MM);
      ensureSpace(lines.length * 4.6);
      y = hebrewParagraph(doc, text, xRight, y, PDF_CONTENT_W_MM, 4.6);
      y += 1.5;
    }
    function bullet(text){
      doc.setFont('NotoHebrew','normal'); doc.setFontSize(9.3); doc.setTextColor(26,26,26);
      const bulletIndent = 4;
      const lines = doc.splitTextToSize(text, PDF_CONTENT_W_MM - bulletIndent);
      ensureSpace(lines.length * 4.6 + 1);
      lines.forEach((line, idx)=>{
        if(idx === 0){
          doc.text('•', xLeft, y);
        }
        hebrewText(doc, line, xRight - bulletIndent, y);
        y += 4.6;
      });
      y += 1;
    }

    drawBanner();

    sectionTitle('שיוך מאמן/ת');
    row('מאמן/ת', data.trainerName);
    row('דוא"ל מאמן/ת', data.trainerEmail);
    y += 3;

    sectionTitle('פרטי המתאמן/ת');
    row('שם פרטי ומשפחה', data.trainee.name);
    row('דוא"ל', data.trainee.email);
    row('נייד', data.trainee.phone);
    row('כתובת', data.trainee.address);
    row('תאריך לידה', data.trainee.dob);
    row('מצב משפחתי', data.trainee.marital);
    row('פרטי עיסוק', data.trainee.occupation);
    y += 3;

    sectionTitle('מצב בריאותי');
    row('טיפול פסיכולוגי/פסיכיאטרי/אימוני קודם', data.health.q1 + (data.health.q1_detail ? ' — '+data.health.q1_detail : ''));
    row('מחלה נפשית מאובחנת', data.health.q2 + (data.health.q2_detail ? ' — '+data.health.q2_detail : ''));
    row('נטילת תרופות קבועה', data.health.q3 + (data.health.q3_detail ? ' — '+data.health.q3_detail : ''));
    y += 3;

    sectionTitle('תהליך האימון והתחייבויות הצדדים');
    [
      'תהליך האימון כולל מספר מפגשים שייערכו בתדירות של פעם בשבוע.',
      'אורכו של כל מפגש אימון 60 דקות. מפגשי האימון יתקיימו באופן פיזי / זום במועד שנתאם מראש.',
      'ניתן לפנות אל המאמנ/ת בהודעת וואטסאפ או בטלפון בין המפגשים.',
      'במקרה שהמתאמנ/ת אינו/ה יכול/ה לקיים את מפגש האימון הבא, עליו/ה להודיע למאמן/ת לפחות 24 שעות מראש ולוודא שההודעה התקבלה.',
      'במקרה זה המאמן/ת והמתאמנ/ת יקבעו מועד חלופי.',
      'המתאמנ/ת מאשר/ת כי קיבל/ה הסבר על תהליך האימון, אופיו ודרכי העבודה בו, ומסכימ/ה לתהליך.',
      'המתאמנ/ת מאשר/ת כי מובן לו/ה שהוא/היא האחראי/ת להחלטותיו/ה ולפעולותיו/ה.',
      'המתאמנ/ת מצהיר/ה כי אינו/ה נמצא/ת בטיפול פסיכיאטרי/פסיכולוגי ו/או אינו/ה נוטל/ת כדורים פסיכיאטריים. ידוע לי כי במקרה כזה, האימון יהיה מותנה בקבלת אישור מהרופא המטפל לעבור תהליך אימון במקביל לטיפול.',
      'המתאמנ/ת מתחייב/ת להגיע לכל מפגשי האימון במועדים שייקבעו.'
    ].forEach(bullet);
    y += 2;

    sectionTitle('סודיות');
    paragraph('האימונים שלנו הם אישיים ופרטיים. המאמן/ת מתחייב/ת לשמור בסודיות מוחלטת את המידע הנמסר על ידך במהלך האימון.');
    paragraph('מובהר ומודגש כי חובת הסודיות אינה בגדר חיסיון וכפופה להוראות הדין. במקרים המחויבים על פי דין, המאמן/ת ינקוט בצעדים המתחייבים, לרבות דיווח לרשויות בהתאם לנסיבות העניין.');
    paragraph('היות והתהליך מתקיים במסגרת קוד המנצח, מעת לעת יעדכן המאמן/ת את מנהל תחום האימון בהתקדמותך בתהליך.');
    y += 2;

    sectionTitle('גילוי נאות');
    paragraph('ידוע לי כי המאמן/ת הוא/היא מאמן/ת אישי/ת ואינו/ה עוסק/ת בכל סוג של טיפול נפשי/גופני, פסיכולוגי או פסיכיאטרי, ואינו/ה מחליף/ה טיפול כזה או אחר. מהות היחסים באימון אינה טיפול פסיכולוגי או כל סוג אחר של טיפול.');
    y += 4;

    ensureSpace(40);
    sectionTitle('חתימות');
    y += 2;
    const sigW = 60, sigH = 22;
    const sigRightX = xRight - sigW;
    const sigLeftX = xLeft;

    if(data.traineeSignature){ doc.addImage(data.traineeSignature, 'PNG', sigRightX, y, sigW, sigH); }
    doc.setDrawColor(180,180,180); doc.setLineWidth(0.3);
    doc.line(sigRightX, y+sigH+2, sigRightX+sigW, y+sigH+2);
    doc.setFont('NotoHebrew','normal'); doc.setFontSize(8); doc.setTextColor(120,120,120);
    hebrewText(doc, 'חתימת המתאמן/ת', sigRightX+sigW, y+sigH+6);
    hebrewText(doc, data.traineeSignedAt ? new Date(data.traineeSignedAt).toLocaleString('he-IL') : '', sigRightX+sigW, y+sigH+10);

    if(data.coachSignature){ doc.addImage(data.coachSignature, 'PNG', sigLeftX, y, sigW, sigH); }
    doc.line(sigLeftX, y+sigH+2, sigLeftX+sigW, y+sigH+2);
    hebrewText(doc, 'חתימת המאמן/ת', sigLeftX+sigW, y+sigH+6);
    hebrewText(doc, data.coachSignedAt ? new Date(data.coachSignedAt).toLocaleString('he-IL') : 'טרם נחתם', sigLeftX+sigW, y+sigH+10);

    const pageTotal = doc.internal.getNumberOfPages();
    for(let p=1; p<=pageTotal; p++){
      doc.setPage(p);
      drawFooter(p, pageTotal);
    }

    return doc;
  }

