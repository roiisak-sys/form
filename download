<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
  :root{
    --navy:#1A2B4C;
    --cream:#FAF8F3;
    --paper:#FFFFFF;
    --line:#E3DFD4;
    --text:#1A1A1A;
    --muted:#5C5C5C;
    --accent:#C8553D;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    font-family:'Assistant',sans-serif;
    background:var(--cream);
    color:var(--text);
    direction:rtl;
    line-height:1.55;
    min-height:100vh;
  }
  .wrap{max-width:760px;margin:0 auto;padding:0 0 60px;}

  .banner{
    background:linear-gradient(135deg,var(--navy) 0%, #142038 100%);
    padding:34px 28px 28px;
    text-align:center;
    position:relative;
    overflow:hidden;
  }
  .banner::before{
    content:"";
    position:absolute;
    inset:-40% -10%;
    background:radial-gradient(circle at 30% 20%, rgba(255,255,255,0.05), transparent 60%);
  }
  .logo-ring{
    width:74px;height:74px;
    border:1.5px solid rgba(255,255,255,0.55);
    border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    margin:0 auto 14px;
    position:relative;
  }
  .logo-ring::before{
    content:"";
    position:absolute;
    width:84px;height:84px;
    border:1px solid rgba(255,255,255,0.25);
    border-radius:50%;
    transform:rotate(18deg);
  }
  .logo-ring span{color:#fff;font-weight:800;font-size:20px;}
  .banner h1{color:#fff;font-size:23px;font-weight:700;margin:0 0 4px;letter-spacing:.2px;}
  .banner p.sub{color:rgba(255,255,255,0.72);font-size:14px;margin:0;letter-spacing:.5px;}

  .progress{display:flex;justify-content:center;gap:6px;padding:18px 20px 0;background:var(--cream);}
  .progress .dot{flex:1;max-width:90px;height:4px;border-radius:3px;background:var(--line);transition:background .25s;}
  .progress .dot.active{background:var(--navy);}
  .progress .dot.done{background:var(--accent);}

  .card{background:var(--paper);margin:20px 20px 0;border-radius:14px;border:1px solid var(--line);padding:26px 24px;}
  .card h2{font-size:18px;color:var(--navy);margin:0 0 4px;font-weight:700;}
  .card .hint{color:var(--muted);font-size:13.5px;margin:0 0 20px;}
  .field{margin-bottom:16px;}
  .field label{display:block;font-size:14px;font-weight:600;color:var(--text);margin-bottom:6px;}
  .field input, .field select, .field textarea{
    width:100%;border:1px solid #D8D3C6;border-radius:9px;padding:11px 13px;
    font-family:inherit;font-size:15px;color:var(--text);background:#fff;transition:border-color .15s;
  }
  .field input:focus, .field select:focus, .field textarea:focus{outline:none;border-color:var(--navy);}
  .row2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
  @media(max-width:480px){.row2{grid-template-columns:1fr;}}

  .yn-block{border:1px solid var(--line);border-radius:10px;padding:14px 14px 12px;margin-bottom:14px;background:#FCFBF8;}
  .yn-q{font-size:14.5px;font-weight:600;margin-bottom:10px;}
  .yn-options{display:flex;gap:10px;margin-bottom:10px;}
  .yn-options label{
    flex:1;display:flex;align-items:center;justify-content:center;gap:6px;
    border:1px solid #D8D3C6;border-radius:8px;padding:9px;font-size:14px;font-weight:600;
    cursor:pointer;color:var(--muted);background:#fff;
  }
  .yn-options input{width:auto;margin:0;accent-color:var(--navy);}
  .yn-options label.checked{border-color:var(--navy);color:var(--navy);background:#EDF0F6;}
  .yn-detail{display:none;}
  .yn-detail.show{display:block;}

  .terms{list-style:none;margin:0;padding:0;}
  .terms li{position:relative;padding-right:22px;margin-bottom:11px;font-size:14.5px;color:var(--text);}
  .terms li::before{content:"";position:absolute;right:0;top:9px;width:6px;height:6px;border-radius:50%;background:var(--navy);}

  .confirm-row{display:flex;align-items:flex-start;gap:10px;background:#FCFBF8;border:1px solid var(--line);border-radius:10px;padding:13px 14px;margin-bottom:12px;}
  .confirm-row input{width:auto;margin-top:3px;accent-color:var(--navy);flex-shrink:0;}
  .confirm-row span{font-size:14px;}

  .sig-pad-wrap{border:1.5px dashed #C9C2B0;border-radius:10px;background:#FDFCF9;position:relative;}
  canvas.sigpad{width:100%;height:160px;display:block;touch-action:none;border-radius:10px;cursor:crosshair;}
  .sig-line-label{position:absolute;bottom:10px;left:14px;right:14px;border-top:1px solid #C9C2B0;text-align:center;color:var(--muted);font-size:12px;padding-top:4px;pointer-events:none;}
  .sig-clear{margin-top:8px;background:none;border:none;color:var(--navy);font-size:13px;font-weight:600;cursor:pointer;padding:4px;text-decoration:underline;}

  .nav-buttons{display:flex;gap:10px;padding:22px 20px 0;}
  .btn{flex:1;border:none;border-radius:10px;padding:14px;font-size:15.5px;font-weight:700;font-family:inherit;cursor:pointer;transition:opacity .15s, transform .1s;text-align:center;text-decoration:none;display:flex;align-items:center;justify-content:center;}
  .btn:active{transform:scale(.98);}
  .btn-primary{background:var(--navy);color:#fff;}
  .btn-primary:disabled{background:#A9B2C2;cursor:not-allowed;}
  .btn-secondary{background:#fff;color:var(--navy);border:1.5px solid var(--navy);}
  .btn-full{width:100%;}

  .summary-row{display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--line);font-size:14px;gap:10px;}
  .summary-row:last-child{border-bottom:none;}
  .summary-row .k{color:var(--muted);flex-shrink:0;}
  .summary-row .v{font-weight:600;text-align:left;word-break:break-word;}

  .badge{display:inline-block;font-size:12px;font-weight:700;padding:3px 10px;border-radius:20px;background:#EDF0F6;color:var(--navy);margin-bottom:10px;}
  .badge.done{background:#E7F0EA;color:#2E6B45;}
  .badge.wait{background:#FBEFE9;color:var(--accent);}

  .footer-note{text-align:center;color:var(--muted);font-size:12.5px;padding:24px 20px 0;}

  .success-screen{padding:50px 30px;text-align:center;}
  .success-screen .check{width:70px;height:70px;border-radius:50%;background:#E7F0EA;color:#2E6B45;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;font-size:34px;}
  .success-screen h2{color:var(--navy);font-size:20px;margin-bottom:8px;}
  .success-screen p{color:var(--muted);font-size:14.5px;max-width:420px;margin:0 auto 22px;}

  .error-text{color:var(--accent);font-size:13px;margin-top:-10px;margin-bottom:14px;display:none;}
  .error-text.show{display:block;}

  .loading-overlay{position:fixed;inset:0;background:rgba(250,248,243,0.92);display:none;align-items:center;justify-content:center;z-index:50;flex-direction:column;gap:12px;}
  .loading-overlay.show{display:flex;}
  .spinner{width:34px;height:34px;border:3px solid var(--line);border-top-color:var(--navy);border-radius:50%;animation:spin 0.8s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}

  .link-box{background:#EDF0F6;border:1px solid var(--navy);border-radius:10px;padding:12px 14px;font-size:13px;color:var(--navy);margin:10px 0;direction:ltr;text-align:left;width:100%;font-family:inherit;cursor:text;}
  .link-box:focus{outline:none;border-color:var(--navy);box-shadow:0 0 0 2px rgba(26,43,76,0.15);}
  .copy-btn{margin-top:6px;background:var(--navy);color:#fff;border:none;border-radius:8px;padding:11px 16px;font-weight:700;font-size:14px;cursor:pointer;width:100%;}
  .copy-btn.copied{background:#2E6B45;}

  .step-search{position:relative;}
  .search-results{position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid var(--line);border-radius:9px;margin-top:4px;max-height:240px;overflow-y:auto;z-index:10;box-shadow:0 6px 18px rgba(0,0,0,0.08);display:none;}
  .search-results.show{display:block;}
  .search-results .opt{padding:11px 13px;font-size:14.5px;cursor:pointer;border-bottom:1px solid var(--line);}
  .search-results .opt:last-child{border-bottom:none;}
  .search-results .opt:hover{background:#EDF0F6;}
  .search-results .opt .sub{color:var(--muted);font-size:12px;}
  .selected-pill{display:flex;align-items:center;justify-content:space-between;border:1px solid var(--navy);background:#EDF0F6;border-radius:9px;padding:11px 13px;font-size:15px;font-weight:600;color:var(--navy);}
  .selected-pill button{background:none;border:none;color:var(--accent);font-size:13px;font-weight:700;cursor:pointer;}

  .readonly-card{background:#FCFBF8;border:1px solid var(--line);border-radius:10px;padding:14px 16px;margin-bottom:16px;}
</style>
</head>
